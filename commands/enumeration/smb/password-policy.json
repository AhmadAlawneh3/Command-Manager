{
  "id": "password-policy",
  "name": "NetExec Password Policy",
  "command": "nxc smb <IP> -u '<user>' -p '<password>' --pass-pol",
  "description": "Enumerate Domain Password Policy",
  "platform": "linux",
  "requires": [
    "password"
  ],
  "protocols": [
    "smb"
  ],
  "tags": [
    "nxc",
    "password-policy",
    "enumeration"
  ],
  "examples": [
    "nxc smb 10.10.11.2 -u 'reddington' -p 'LizKeen' --pass-pol"
  ]
}
